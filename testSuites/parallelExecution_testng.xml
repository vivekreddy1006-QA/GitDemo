<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Suite" parallel="tests" thread-count="5"><!-- This will run tests parallely and max tests that can run parallely are 5,
if we mention parallel="methods", it will run the methods parallely inside the tests also-->
  <test thread-count="5" name="Error Validations Test">
    <classes>
      <class name="vivek.TestClasses.ErrorValidations"/>
    </classes>
  </test> <!-- Test -->
  <test thread-count="5" name="Submit Order Test">
    <classes>
    <class name="vivek.TestClasses.FrameWorkTest"/>
    </classes>
  </test>
</suite> <!-- Suite -->
